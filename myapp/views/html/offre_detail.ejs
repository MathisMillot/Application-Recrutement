<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — <%= offre.intitule || 'Offre' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../CSS/base.css" />
  <link rel="stylesheet" href="../CSS/components.css" />
  <link rel="stylesheet" href="../CSS/offres.css" />
  <style>
    .detail-layout { max-width: 900px; margin: 40px auto; padding: 0 24px; display: grid; grid-template-columns: 1fr 320px; gap: 32px; }
    .detail-main { background: #fff; border-radius: 16px; padding: 36px 40px; }
    .detail-sidebar { display: flex; flex-direction: column; gap: 16px; }
    .detail-sidebar__card { background: #fff; border-radius: 16px; padding: 24px; display: flex; flex-direction: column; gap: 12px; }
    .detail-title { font-size: 28px; font-weight: 700; color: var(--color-dark); margin-bottom: 8px; line-height: 1.2; }
    .detail-company { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
    .detail-company__logo { width: 44px; height: 44px; border-radius: 10px; object-fit: cover; flex-shrink: 0; }
    .detail-company__logo-placeholder { width: 44px; height: 44px; border-radius: 10px; background: var(--color-primary); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; color: white; flex-shrink: 0; }
    .detail-company__name { font-weight: 600; font-size: 16px; }
    .detail-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
    .detail-section { margin-top: 24px; }
    .detail-section h3 { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: #888; margin-bottom: 10px; border-bottom: 1px solid #eee; padding-bottom: 6px; }
    .detail-section p { font-size: 15px; color: #444; line-height: 1.7; white-space: pre-wrap; }
    .detail-section ul { padding-left: 18px; font-size: 15px; color: #444; line-height: 1.8; }
    .btn-postuler { display: block; width: 100%; padding: 14px; background: var(--color-primary); border: none; border-radius: 12px; font-family: inherit; font-size: 16px; font-weight: 700; color: var(--color-dark); cursor: pointer; text-align: center; text-decoration: none; transition: opacity 0.2s; }
    .btn-postuler:hover { opacity: 0.88; }
    @media (max-width: 700px) { .detail-layout { grid-template-columns: 1fr; } }
  </style>
</head>
<body>

  <nav class="navbar">
    <a class="navbar__brand" href="/offres">
      <img src="/images/logo_landr.png" alt="Landr logo" />
      <span>Landr</span>
    </a>
    <div class="navbar__nav">
      <a href="/offres">Trouver un job</a>
      <a href="/organisations">Trouver une entreprise</a>
    </div>
    <% if (user) { %>
      <div class="navbar__user" id="user-menu">
        <div class="navbar__avatar">
          <% if (user.photo_profil) { %>
            <img src="/uploads/<%= user.photo_profil %>" alt="avatar" />
          <% } else { %>
            <%= user.prenom[0] %><%= user.nom[0] %>
          <% } %>
        </div>
        <span>Mon espace</span>
        <div class="user-dropdown" id="user-dropdown">
          <a href="/profil_candidat">Mon profil</a>
          <a href="/modifier_profil">Modifier mon profil</a>
          <div class="dropdown-divider"></div>
          <form method="POST" action="/logout" style="margin:0;padding:0">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="dropdown-logout">Se déconnecter</button>
          </form>
        </div>
      </div>
    <% } else { %>
      <a href="/connection" class="btn btn--primary" style="white-space:nowrap">Se connecter</a>
    <% } %>
  </nav>

  <div style="max-width:900px; margin:24px auto; padding:0 24px;">
    <a href="/offres" style="font-size:14px; color:#888; text-decoration:none;">← Retour aux offres</a>
  </div>

  <div class="detail-layout">

    <!-- Contenu principal -->
    <article class="detail-main">

      <% if (offre.photo) { %>
        <img src="/uploads/<%= offre.photo %>" alt="<%= offre.intitule %>"
             style="width:100%; max-height:220px; object-fit:cover; border-radius:12px; margin-bottom:24px;" />
      <% } %>

      <h1 class="detail-title"><%= offre.intitule || offre.nom_poste || 'Offre #' + offre.id_offre %></h1>

      <div class="detail-company">
        <% if (offre.organisation_photo) { %>
          <img src="/uploads/<%= offre.organisation_photo %>" alt="<%= offre.organisation %>" class="detail-company__logo" />
        <% } else { %>
          <div class="detail-company__logo-placeholder">
            <%= (offre.organisation || '??').substring(0, 2).toUpperCase() %>
          </div>
        <% } %>
        <a href="/organisations/<%= offre.siren_organisation %>" class="detail-company__name" style="text-decoration:none; color:inherit;">
          <%= offre.organisation || '—' %>
        </a>
      </div>

      <div class="detail-tags">
        <% if (offre.type_contrat) { %><span class="tag">📄 <%= offre.type_contrat %></span><% } %>
        <% if (offre.lieu) { %><span class="tag">📍 <%= offre.lieu %></span><% } %>
        <% if (offre.remote && offre.remote !== 'non') { %>
          <span class="tag">🏠 <%= offre.remote === 'full' ? 'Full remote' : 'Hybride' %></span>
        <% } %>
        <% if (offre.statut_poste) { %><span class="tag"><%= offre.statut_poste %></span><% } %>
        <% if (offre.type_metier) { %><span class="tag">🔧 <%= offre.type_metier %></span><% } %>
        <% if (offre.salaire_min) { %>
          <span class="tag">💶 <%= offre.salaire_min.toLocaleString('fr-FR') %>€
            <% if (offre.salaire_max) { %> – <%= offre.salaire_max.toLocaleString('fr-FR') %>€<% } %>
          </span>
        <% } %>
      </div>

      <% if (offre.rythme) { %>
        <div class="detail-section">
          <h3>Rythme de travail</h3>
          <p><%= offre.rythme %></p>
        </div>
      <% } %>

      <% if (offre.description || offre.fiche_description) { %>
        <div class="detail-section">
          <h3>Description du poste</h3>
          <p><%= offre.description || offre.fiche_description %></p>
        </div>
      <% } %>

      <% if (offre.responsable) { %>
        <div class="detail-section">
          <h3>Responsable hiérarchique</h3>
          <p><%= offre.responsable %></p>
        </div>
      <% } %>

      <% if (offre.pieces_demandees) { %>
        <div class="detail-section">
          <h3>Pièces demandées</h3>
          <p><%= offre.pieces_demandees %></p>
        </div>
      <% } %>

    </article>

    <!-- Sidebar action -->
    <aside class="detail-sidebar">
      <div class="detail-sidebar__card">
        <p style="font-size:13px; color:#888; margin:0;">Expire le</p>
        <p style="font-weight:700; font-size:15px; margin:0;">
          <%= new Date(offre.date_expiration).toLocaleDateString('fr-FR') %>
        </p>

        <% if (user && user.role === 'Candidat') { %>
          <a href="/candidature?id=<%= offre.id_offre %>" class="btn-postuler">Postuler à cette offre</a>
        <% } else if (!user) { %>
          <a href="/connection" class="btn-postuler">Se connecter pour postuler</a>
        <% } %>
      </div>

      <% if (offre.organisation) { %>
        <div class="detail-sidebar__card">
          <p style="font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; color:#888; margin:0;">À propos de l'entreprise</p>
          <% if (offre.organisation_photo) { %>
            <img src="/uploads/<%= offre.organisation_photo %>" alt="<%= offre.organisation %>"
                 style="width:60px; height:60px; object-fit:cover; border-radius:10px;" />
          <% } %>
          <p style="font-weight:600; font-size:15px; margin:0;"><%= offre.organisation %></p>
          <a href="/organisations/<%= offre.siren_organisation %>"
             style="font-size:13px; color:var(--color-primary); text-decoration:none; font-weight:600;">
            Voir l'organisation →
          </a>
        </div>
      <% } %>
    </aside>

  </div>

  <script>
    const menu = document.getElementById('user-menu');
    const dropdown = document.getElementById('user-dropdown');
    if (menu && dropdown) {
      menu.addEventListener('click', e => { e.stopPropagation(); dropdown.classList.toggle('open'); });
      document.addEventListener('click', () => dropdown.classList.remove('open'));
    }
  </script>
</body>
</html>
