<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — Mon espace</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../CSS/base.css" />
  <link rel="stylesheet" href="../CSS/components.css" />
  <style>
    /* ── Styles spécifiques à la page profil candidat ── */

    body { min-height: 100vh; }

    /* ── Layout ── */
    .layout {
      display: grid;
      grid-template-columns: 230px 1fr;
      min-height: calc(100vh - 80px);
    }

    /* ── Sidebar ── */
    .sidebar {
      background: var(--color-white);
      border-right: 1px solid var(--color-border);
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    .sidebar__section-title {
      font-weight: 700;
      font-size: 20px;
      color: var(--color-dark);
      margin-bottom: 12px;
    }

    .sidebar__list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .sidebar__list a {
      font-size: 15px;
      font-weight: 500;
      color: var(--color-dark);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .sidebar__list a:hover { color: var(--color-primary); }

    .sidebar__exp-item { margin-bottom: 12px; }

    .sidebar__exp-item strong {
      display: block;
      font-size: 15px;
      font-weight: 600;
      color: var(--color-dark);
    }

    .sidebar__exp-item span {
      font-size: 13px;
      color: var(--color-medium);
    }

    /* ── Main ── */
    .main {
      padding: 24px 32px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    /* ── Profil card ── */
    .profile-card {
      background: var(--color-white);
      border-radius: 16px;
      padding: 32px 40px;
      display: flex;
      align-items: center;
      gap: 40px;
    }

    .profile-card__avatar {
      width: 130px;
      height: 130px;
      border-radius: 50%;
      border: 2px solid var(--color-dark);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 36px;
      color: var(--color-dark);
      flex-shrink: 0;
    }

    .profile-card__info {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .profile-card__name {
      font-weight: 700;
      font-size: 42px;
      line-height: 1.1;
      color: var(--color-dark);
    }

    .profile-card__title {
      font-size: 16px;
      color: var(--color-dark);
      margin-bottom: 4px;
    }

    .profile-card__divider {
      width: 48px;
      height: 3px;
      background: var(--color-dark);
      border-radius: 2px;
      margin: 4px 0 8px;
    }

    .profile-card__contact { display: flex; flex-direction: column; gap: 4px; }
    .profile-card__contact span { font-size: 15px; color: var(--color-dark); }

    /* ── Candidatures ── */
    .section-title {
      font-weight: 700;
      font-size: 36px;
      color: var(--color-dark);
      margin-bottom: 4px;
    }

    .candidatures-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .job-card {
      background: var(--color-white);
      border-radius: 12px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .job-card__img-placeholder {
      width: 100%;
      height: 140px;
      background: linear-gradient(135deg, #ddd 0%, #bbb 100%);
    }

    .job-card__body {
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .job-card__title {
      font-weight: 700;
      font-size: 15px;
      color: var(--color-dark);
      line-height: 1.3;
    }

    .job-card__company { display: flex; align-items: center; gap: 6px; }

    .company-logo {
      width: 22px;
      height: 22px;
      border-radius: 4px;
      background: var(--color-primary);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      font-weight: 700;
      color: white;
      flex-shrink: 0;
    }

    .company-logo--blue { background: #3B3B8E; }
    .company-logo--teal { background: #00897B; }

    .job-card__company span {
      font-size: 12px;
      font-weight: 600;
      color: var(--color-dark);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .job-card__footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 16px 14px;
    }

    .job-card__date { font-size: 12px; color: var(--color-medium); }

    .job-card__actions { display: flex; gap: 10px; }
    .job-card__actions svg { color: var(--color-medium); cursor: pointer; }
    .job-card__actions svg:hover { color: var(--color-dark); }
  </style>
</head>
<body>

  <!-- ══ NAVBAR ══ -->
  <nav class="navbar">
    <a href="/accueil" class="navbar__brand">
      <img src="/images/logo_landr.png" alt="Landr" />
      <span>Landr</span>
    </a>

    <div class="navbar__nav">
      <a href="/offres">Trouver un job</a>
      <a href="#">Trouver une entreprise</a>
    </div>

    <div class="navbar__search">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <circle cx="6.5" cy="6.5" r="5" stroke="#888" stroke-width="1.5"/>
        <path d="M10.5 10.5L14 14" stroke="#888" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <input type="text" placeholder="Chercher un job..." />
    </div>

    <div class="navbar__user">
      <div class="navbar__avatar"><%= user.prenom[0] %><%= user.nom[0] %></div>
      <span>Mon espace</span>
    </div>
  </nav>

  <!-- ══ LAYOUT ══ -->
  <div class="layout">

    <!-- Sidebar -->
    <aside class="sidebar">
      <div>
        <p class="sidebar__section-title">Mes documents</p>
        <div class="sidebar__list">
          <% if (documents.length === 0) { %>
            <span style="font-size:13px; color:var(--color-medium)">Aucun document déposé</span>
          <% } else { %>
            <% documents.forEach(function(doc) { %>
              <a href="/uploads/<%= doc %>" target="_blank"><%= doc %></a>
            <% }); %>
          <% } %>
        </div>
        <form method="POST" action="/upload" enctype="multipart/form-data" style="margin-top:12px">
          <input type="file" name="document" accept=".pdf,.doc,.docx" required
            style="font-size:13px; width:100%; margin-bottom:8px" />
          <button type="submit" class="btn btn--primary"
            style="width:100%; height:36px; font-size:14px">Déposer</button>
        </form>
      </div>

      <div>
        <p class="sidebar__section-title">Mes expériences</p>
        <div>
          <div class="sidebar__exp-item">
            <strong>Expérience 1</strong>
            <span>Début - Fin</span>
          </div>
          <div class="sidebar__exp-item">
            <strong>Expérience 2</strong>
            <span>Début - Fin</span>
          </div>
          <div class="sidebar__exp-item">
            <strong>Expérience 3</strong>
            <span>Début - Fin</span>
          </div>
        </div>
      </div>
    </aside>

    <!-- Main -->
    <main class="main">

      <!-- Profil -->
      <div class="profile-card">
        <div class="profile-card__avatar"><%= user.prenom[0] %><%= user.nom[0] %></div>
        <div class="profile-card__info">
          <h1 class="profile-card__name">Bonjour <%= user.prenom %>,</h1>
          <div class="profile-card__divider"></div>
          <div class="profile-card__contact">
            <span><%= user.email %></span>
            <% if (user.num_tel) { %><span><%= user.num_tel %></span><% } %>
          </div>
        </div>
      </div>

      <!-- Candidatures -->
      <div>
        <h2 class="section-title">Mes candidatures</h2>

        <% if (candidatures.length === 0) { %>
          <p style="color: var(--color-medium)">Aucune candidature pour l'instant.</p>
        <% } else { %>
        <div class="candidatures-grid">
          <% candidatures.forEach(function(c) { %>
            <div class="job-card">
              <div class="job-card__img-placeholder"></div>
              <div class="job-card__body">
                <p class="job-card__title"><%= c.offre_description || 'Offre #' + c.id_offre %></p>
                <div class="job-card__tags">
                  <span class="tag">🗓 <%= new Date(c.date).toLocaleDateString('fr-FR') %></span>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
        <% } %>
      </div>

    </main>
  </div>

</body>
</html>
