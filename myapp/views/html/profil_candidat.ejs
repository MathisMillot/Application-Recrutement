<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — Mon espace</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="template.css" />
  <style>
    :root {
      --color-primary:  #ECC023;
      --color-dark:     #2D2D2D;
      --color-medium:   #5A5A5A;
      --color-light-bg: #F0F0F0;
      --color-white:    #FFFFFF;
      --color-border:   #D8D8D8;
      --font-main:      'Space Grotesk', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-main);
      background-color: var(--color-light-bg);
      color: var(--color-dark);
      min-height: 100vh;
    }

    /* ══════════════════════════════
       NAVBAR
    ══════════════════════════════ */
    .navbar {
      display: flex;
      align-items: center;
      gap: 40px;
      padding: 16px 40px;
      background: var(--color-white);
      border-bottom: 1px solid var(--color-border);
    }

    .navbar__logo {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-decoration: none;
      gap: 2px;
      flex-shrink: 0;
    }

    .navbar__logo img {
      width: 44px;
      mix-blend-mode: multiply;
    }

    .navbar__logo span {
      font-weight: 700;
      font-size: 14px;
      color: var(--color-dark);
    }

    .navbar__links {
      display: flex;
      gap: 40px;
      flex: 1;
      justify-content: center;
    }

    .navbar__links a {
      text-decoration: none;
      font-weight: 600;
      font-size: 16px;
      color: var(--color-dark);
      white-space: nowrap;
    }

    .navbar__links a:hover { color: var(--color-primary); }

    .navbar__search {
      display: flex;
      align-items: center;
      gap: 10px;
      background: var(--color-white);
      border: 1.5px solid var(--color-border);
      border-radius: 28px;
      padding: 10px 20px;
      flex: 0 0 240px;
    }

    .navbar__search input {
      border: none;
      outline: none;
      font-family: var(--font-main);
      font-size: 15px;
      color: var(--color-medium);
      background: transparent;
      width: 100%;
    }

    .navbar__search svg { flex-shrink: 0; }

    .navbar__user {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      margin-left: auto;
      cursor: pointer;
    }

    .navbar__avatar {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      border: 2px solid var(--color-dark);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 16px;
      color: var(--color-dark);
      background: var(--color-white);
    }

    .navbar__user span {
      font-size: 13px;
      font-weight: 500;
      color: var(--color-dark);
    }

    /* ══════════════════════════════
       LAYOUT
    ══════════════════════════════ */
    .layout {
      display: grid;
      grid-template-columns: 230px 1fr;
      min-height: calc(100vh - 81px);
    }

    /* ══════════════════════════════
       SIDEBAR
    ══════════════════════════════ */
    .sidebar {
      background: var(--color-white);
      border-right: 1px solid var(--color-border);
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    .sidebar__section-title {
      font-weight: 700;
      font-size: 20px;
      color: var(--color-dark);
      margin-bottom: 12px;
    }

    .sidebar__list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .sidebar__list a {
      font-size: 15px;
      font-weight: 500;
      color: var(--color-dark);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .sidebar__list a:hover { color: var(--color-primary); }

    .sidebar__exp-item {
      margin-bottom: 12px;
    }

    .sidebar__exp-item strong {
      display: block;
      font-size: 15px;
      font-weight: 600;
      color: var(--color-dark);
    }

    .sidebar__exp-item span {
      font-size: 13px;
      color: var(--color-medium);
    }

    /* ══════════════════════════════
       MAIN CONTENT
    ══════════════════════════════ */
    .main {
      padding: 24px 32px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    /* ── Profil card ── */
    .profile-card {
      background: var(--color-white);
      border-radius: 16px;
      padding: 32px 40px;
      display: flex;
      align-items: center;
      gap: 40px;
    }

    .profile-card__avatar {
      width: 130px;
      height: 130px;
      border-radius: 50%;
      border: 2px solid var(--color-dark);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 36px;
      color: var(--color-dark);
      flex-shrink: 0;
    }

    .profile-card__info {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .profile-card__name {
      font-weight: 700;
      font-size: 42px;
      line-height: 1.1;
      color: var(--color-dark);
    }

    .profile-card__title {
      font-size: 16px;
      color: var(--color-dark);
      margin-bottom: 4px;
    }

    .profile-card__divider {
      width: 48px;
      height: 3px;
      background: var(--color-dark);
      border-radius: 2px;
      margin: 4px 0 8px;
    }

    .profile-card__contact {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .profile-card__contact span {
      font-size: 15px;
      color: var(--color-dark);
    }

    /* ── Candidatures ── */
    .section-title {
      font-weight: 700;
      font-size: 36px;
      color: var(--color-dark);
      margin-bottom: 4px;
    }

    .candidatures-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .job-card {
      background: var(--color-white);
      border-radius: 12px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .job-card__img {
      width: 100%;
      height: 140px;
      object-fit: cover;
      background: #ccc;
    }

    .job-card__img-placeholder {
      width: 100%;
      height: 140px;
      background: linear-gradient(135deg, #ddd 0%, #bbb 100%);
    }

    .job-card__body {
      padding: 14px 16px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .job-card__title {
      font-weight: 700;
      font-size: 15px;
      color: var(--color-dark);
      line-height: 1.3;
    }

    .job-card__company {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .company-logo {
      width: 22px;
      height: 22px;
      border-radius: 4px;
      background: var(--color-primary);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      font-weight: 700;
      color: white;
      flex-shrink: 0;
    }

    .company-logo--blue { background: #3B3B8E; }
    .company-logo--teal { background: #00897B; }

    .job-card__company span {
      font-size: 12px;
      font-weight: 600;
      color: var(--color-dark);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .job-card__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: var(--color-light-bg);
      border-radius: 20px;
      padding: 3px 10px;
      font-size: 12px;
      color: var(--color-medium);
    }

    .job-card__footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 16px 14px;
    }

    .job-card__date {
      font-size: 12px;
      color: var(--color-medium);
    }

    .job-card__actions {
      display: flex;
      gap: 10px;
    }

    .job-card__actions svg {
      color: var(--color-medium);
      cursor: pointer;
    }

    .job-card__actions svg:hover { color: var(--color-dark); }
  </style>
</head>
