<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — Candidats</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/admin.css" />
  <style>
    .candidat-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--color-primary, #ECC023);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 13px;
      color: #2D2D2D;
      flex-shrink: 0;
      overflow: hidden;
    }
    .candidat-avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .offre-banner {
      background: var(--color-white, #fff);
      border-radius: 12px;
      padding: 20px 28px;
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 24px;
    }
    .offre-banner__img {
      width: 72px;
      height: 72px;
      border-radius: 10px;
      object-fit: cover;
      flex-shrink: 0;
      background: #eee;
    }
    .offre-banner__placeholder {
      width: 72px;
      height: 72px;
      border-radius: 10px;
      background: linear-gradient(135deg, #eee, #ccc);
      flex-shrink: 0;
    }
  </style>
</head>

<body>
  <div class="admin-layout">

    <!-- Sidebar -->
    <aside class="admin-sidebar">
      <div class="admin-sidebar__title">Landr Recruteur</div>
      <a href="/recruteur">Dashboard</a>
      <a href="/recruteur/offres/nouvelle">+ Nouvelle offre</a>
      <hr class="admin-sidebar__divider" />
      <a href="/offres">← Retour au site</a>
      <form method="POST" action="/logout" class="admin-sidebar__form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="admin-sidebar__logout">Se déconnecter</button>
      </form>
    </aside>

    <!-- Contenu -->
    <main class="admin-main">

      <div class="admin-header">
        <h1>Candidatures</h1>
        <a href="/recruteur" style="font-size:14px; color:#888; text-decoration:none;">← Retour au dashboard</a>
      </div>

      <!-- Bannière offre -->
      <div class="offre-banner">
        <% if (offre.photo) { %>
          <img src="/uploads/<%= offre.photo %>" alt="<%= offre.intitule %>" class="offre-banner__img" />
        <% } else { %>
          <div class="offre-banner__placeholder"></div>
        <% } %>
        <div>
          <h2 style="font-size:20px; font-weight:700; margin-bottom:4px;"><%= offre.intitule || '—' %></h2>
          <span style="font-size:14px; color:#888;"><%= offre.organisation %></span>
          <% if (offre.lieu) { %><span style="font-size:14px; color:#888;"> · <%= offre.lieu %></span><% } %>
          <div style="margin-top:6px;">
            <% const expire = new Date(offre.date_expiration) < new Date(); %>
            <span class="badge badge--<%= expire ? 'expiree' : offre.statut %>"><%= expire ? 'Expirée' : offre.statut %></span>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats-row">
        <div class="stat-chip">
          <span class="stat-chip__label">Candidatures reçues</span>
          <span class="stat-chip__value"><%= candidatures.length %></span>
        </div>
      </div>

      <!-- Tableau candidats -->
      <div class="section-card">
        <% if (candidatures.length === 0) { %>
          <p style="color:#888; padding:16px 0;">Aucun candidat pour cette offre pour l'instant.</p>
        <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Candidat</th>
              <th>Email</th>
              <th>Téléphone</th>
              <th>Disponibilité</th>
              <th>CV</th>
              <th>Lettre de motivation</th>
              <th>Date de candidature</th>
            </tr>
          </thead>
          <tbody>
            <% candidatures.forEach(function(c) { %>
            <tr>
              <td>
                <div style="display:flex; align-items:center; gap:10px;">
                  <div class="candidat-avatar">
                    <% if (c.photo_profil) { %>
                      <img src="/uploads/<%= c.photo_profil %>" alt="avatar" />
                    <% } else { %>
                      <%= c.prenom[0] %><%= c.nom[0] %>
                    <% } %>
                  </div>
                  <span><strong><%= c.prenom %> <%= c.nom %></strong></span>
                </div>
              </td>
              <td><a href="mailto:<%= c.email %>" style="color: var(--color-primary, #ECC023);"><%= c.email %></a></td>
              <td><%= c.num_tel || '—' %></td>
              <td><%= c.dispo || '—' %></td>
              <td>
                <% if (c.cv) { %>
                  <a href="/documents/<%= encodeURIComponent(c.cv) %>" target="_blank" style="color: var(--color-primary, #ECC023); font-size:13px;">Télécharger</a>
                <% } else { %>
                  <span style="color:#bbb;">—</span>
                <% } %>
              </td>
              <td>
                <% if (c.lm) { %>
                  <a href="/documents/<%= encodeURIComponent(c.lm) %>" target="_blank" style="color: var(--color-primary, #ECC023); font-size:13px;">Télécharger</a>
                <% } else { %>
                  <span style="color:#bbb;">—</span>
                <% } %>
              </td>
              <td><%= new Date(c.date).toLocaleDateString('fr-FR') %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
        <% } %>
      </div>

    </main>
  </div>
</body>

</html>
