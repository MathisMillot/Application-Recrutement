<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — Trouver un job</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="../CSS/base.css" />
  <link rel="stylesheet" href="../CSS/components.css" />
  <link rel="stylesheet" href="../CSS/offres.css" />
</head>

<body>

  <!-- ── Navbar ──────────────────────────────────────────────── -->
  <nav class="navbar">
    <a class="navbar__brand" href="/accueil">
      <img src="/images/logo_landr.png" alt="Landr logo" />
      <span>Landr</span>
    </a>
    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
    <div class="navbar__nav">
      <a href="#">Trouver un job</a>
      &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
      <a href="#">Trouver une entreprise</a>
    </div>
    <div class="navbar__search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      <input type="text" placeholder="Chercher un job..." />
    </div>
    <a class="navbar__user" href="<%= user ? '/profil_candidat' : '/connection' %>">
      <div class="navbar__avatar"><%= user ? user.prenom[0] + user.nom[0] : '?' %></div>
      <span>Mon espace</span>
    </a>
  </nav>

  <!-- ── Filtres ─────────────────────────────────────────────── -->
  <div class="filters">
    <!-- Icône filtre générique réutilisée pour chaque chip -->
    <button class="filter-chip">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="7" width="20" height="10" rx="2" />
        <path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" />
      </svg>
      Salaire
    </button>
    <button class="filter-chip">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="7" width="20" height="10" rx="2" />
        <path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" />
      </svg>
      Localisation
    </button>
    <button class="filter-chip">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="7" width="20" height="10" rx="2" />
        <path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" />
      </svg>
      Type de contrat
    </button>
    <button class="filter-chip">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="7" width="20" height="10" rx="2" />
        <path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" />
      </svg>
      Télétravail
    </button>
    <button class="filter-chip">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="7" width="20" height="10" rx="2" />
        <path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" />
      </svg>
      Secteur
    </button>
    <button class="filter-chip filter-chip--all">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="6" x2="20" y2="6" />
        <line x1="8" y1="12" x2="20" y2="12" />
        <line x1="12" y1="18" x2="20" y2="18" />
      </svg>
      Tous les filtres
    </button>
  </div>

  <!-- ── Grille d'offres ────────────────────────────────────── -->
  <section class="offers-section">
    <div class="offers-grid">
      <% offres.forEach(function(offre) { %>
        <article class="offer-card" style="cursor:pointer"
          onclick="window.location='/candidature?id=<%= offre.id_offre %>'">
          <div class="offer-card__image-placeholder">Photo de l'entreprise</div>
          <div class="offer-card__body">
            <h2 class="offer-card__title"><%= offre.description || 'Offre #' + offre.id_offre %></h2>
            <div class="offer-card__company">
              <div class="offer-card__company-logo-placeholder">
                <%= offre.organisation.substring(0, 2).toUpperCase() %>
              </div>
              <span class="offer-card__company-name"><%= offre.organisation %></span>
            </div>
            <div class="offer-card__tags">
              <span class="tag"><%= offre.statut %></span>
            </div>
          </div>
          <div class="offer-card__footer">
            <span class="offer-card__date">
              Expire le <%= new Date(offre.date_expiration).toLocaleDateString('fr-FR') %>
            </span>
            <div class="offer-card__actions">
              <button title="Voir l'offre">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>
        </article>
      <% }); %>
    </div>
  </section>


</body>

</html>