<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — Trouver un job</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="../CSS/base.css" />
  <link rel="stylesheet" href="../CSS/components.css" />
  <link rel="stylesheet" href="../CSS/offres.css" />
</head>

<body>

  <!-- ── Navbar ──────────────────────────────────────────────── -->
  <nav class="navbar">
    <a class="navbar__brand" href="/accueil">
      <img src="/images/logo_landr.png" alt="Landr logo" />
      <span>Landr</span>
    </a>
    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
    <div class="navbar__nav">
      <a href="#">Trouver un job</a>
      &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
      <a href="#">Trouver une entreprise</a>
    </div>
    <form class="navbar__search" method="GET" action="/offres">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      <input type="text" name="q" placeholder="Chercher un job, une entreprise..." value="<%= typeof q !== 'undefined' ? q : '' %>" />
      <button type="submit" style="display: none;">Chercher</button>
    </form>
    <a class="navbar__user" href="<%= user ? '/profil_candidat' : '/connection' %>">
      <div class="navbar__avatar"><%= user ? user.prenom[0] + user.nom[0] : '?' %></div>
      <span>Mon espace</span>
    </a>
  </nav>

  <!-- ── Filtres ─────────────────────────────────────────────── -->
<div class="filters">
    
    <!-- Filtre : Salaire -->
    <div class="filter-wrapper">
      <button class="filter-chip" data-target="dropdown-salaire">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="7" width="20" height="10" rx="2" />
          <path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" />
        </svg>
        Salaire
      </button>
      <div class="filter-dropdown" id="dropdown-salaire">
        <label>Salaire minimum (€)</label>
        <input type="number" placeholder="Ex: 35000" />
        <button class="btn btn--primary" style="height: 38px; width: 100%; font-size: 14px; border-radius: 8px;">Appliquer</button>
      </div>
    </div>

    <!-- Filtre : Localisation -->
    <div class="filter-wrapper">
      <button class="filter-chip" data-target="dropdown-localisation">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        Localisation
      </button>
      <div class="filter-dropdown" id="dropdown-localisation">
        <label>Ville ou Code Postal</label>
        <input type="text" placeholder="Ex: Paris, Lyon..." />
        <button class="btn btn--primary" style="height: 38px; width: 100%; font-size: 14px; border-radius: 8px;">Appliquer</button>
      </div>
    </div>

    <!-- Filtre : Type de contrat -->
    <div class="filter-wrapper">
      <button class="filter-chip" data-target="dropdown-contrat">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="16" y1="13" x2="8" y2="13"></line>
          <line x1="16" y1="17" x2="8" y2="17"></line>
          <polyline points="10 9 9 9 8 9"></polyline>
        </svg>
        Type de contrat
      </button>
      <div class="filter-dropdown" id="dropdown-contrat">
        <label>Contrat souhaité</label>
        <select>
          <option value="">Tous les contrats</option>
          <option value="CDI">CDI</option>
          <option value="CDD">CDD</option>
          <option value="Stage">Stage</option>
          <option value="Alternance">Alternance</option>
        </select>
        <button class="btn btn--primary" style="height: 38px; width: 100%; font-size: 14px; border-radius: 8px;">Appliquer</button>
      </div>
    </div>

    <button class="filter-chip filter-chip--all">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="6" x2="20" y2="6" />
        <line x1="8" y1="12" x2="20" y2="12" />
        <line x1="12" y1="18" x2="20" y2="18" />
      </svg>
      Tous les filtres
    </button>
  </div>

  <!-- ── Grille d'offres ────────────────────────────────────── -->
  <section class="offers-section">
    <div class="offers-grid">
      <% offres.forEach(function(offre) { %>
        <article class="offer-card" style="cursor:pointer"
          onclick="window.location='/candidature?id=<%= offre.id_offre %>'">
          <div class="offer-card__image-placeholder">Photo de l'entreprise</div>
          <div class="offer-card__body">
            <h2 class="offer-card__title"><%= offre.description || 'Offre #' + offre.id_offre %></h2>
            <div class="offer-card__company">
              <div class="offer-card__company-logo-placeholder">
                <%= offre.organisation.substring(0, 2).toUpperCase() %>
              </div>
              <span class="offer-card__company-name"><%= offre.organisation %></span>
            </div>
            <div class="offer-card__tags">
              <span class="tag"><%= offre.statut %></span>
            </div>
          </div>
          <div class="offer-card__footer">
            <span class="offer-card__date">
              Expire le <%= new Date(offre.date_expiration).toLocaleDateString('fr-FR') %>
            </span>
            <div class="offer-card__actions">
              <button title="Voir l'offre">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
            </div>
          </div>
        </article>
      <% }); %>
    </div>
  </section>

  <script>
    const filterButtons = document.querySelectorAll('.filter-chip[data-target]');
    
    // Gérer le clic sur les boutons
    filterButtons.forEach(btn => {
      btn.addEventListener('click', function(e) {
        // Empêche le clic de se propager au document (pour ne pas fermer tout de suite)
        e.stopPropagation();

        const targetId = this.getAttribute('data-target');
        const targetDropdown = document.getElementById(targetId);
        const isActive = this.classList.contains('filter-chip--active');

        // 1. Fermer tous les menus et désactiver tous les boutons
        document.querySelectorAll('.filter-dropdown').forEach(dd => dd.classList.remove('show'));
        document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('filter-chip--active'));

        // 2. Si le bouton cliqué n'était pas déjà actif, on l'ouvre
        if (!isActive && targetDropdown) {
          this.classList.add('filter-chip--active');
          targetDropdown.classList.add('show');
        }
      });
    });

    // Empêcher la fermeture quand on clique à l'intérieur du menu déroulant
    document.querySelectorAll('.filter-dropdown').forEach(dropdown => {
      dropdown.addEventListener('click', function(e) {
        e.stopPropagation();
      });
    });

    // Fermer les menus si on clique n'importe où ailleurs sur la page
    document.addEventListener('click', function() {
      document.querySelectorAll('.filter-dropdown').forEach(dd => dd.classList.remove('show'));
      document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('filter-chip--active'));
    });
  </script>


</body>

</html>