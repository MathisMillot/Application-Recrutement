<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — Trouver un job</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="../CSS/base.css" />
  <link rel="stylesheet" href="../CSS/components.css" />
  <link rel="stylesheet" href="../CSS/offres.css" />
</head>

<body>

  <!-- ── Navbar ──────────────────────────────────────────────── -->
  <nav class="navbar">
    <a class="navbar__brand" href="#">
      <img src="/images/logo_landr.png" alt="Landr logo" />
      <span>Landr</span>
    </a>
    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
    <div class="navbar__nav">
      <a href="#">Trouver un job</a>
      &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
      <a href="#">Trouver une entreprise</a>
    </div>
    <div class="navbar__search">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
        stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      <input type="text" placeholder="Chercher un job..." />
    </div>
    <a class="navbar__user" href="#">
      <div class="navbar__avatar">PP</div>
      <span>Mon espace</span>
    </a>
  </nav>

  <!-- ── Filtres ─────────────────────────────────────────────── -->
  <div class="filters">
    <!-- Icône filtre générique réutilisée pour chaque chip -->
    <button class="filter-chip">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="7" width="20" height="10" rx="2" />
        <path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" />
      </svg>
      Salaire
    </button>
    <button class="filter-chip">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="7" width="20" height="10" rx="2" />
        <path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" />
      </svg>
      Localisation
    </button>
    <button class="filter-chip">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="7" width="20" height="10" rx="2" />
        <path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" />
      </svg>
      Type de contrat
    </button>
    <button class="filter-chip">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="7" width="20" height="10" rx="2" />
        <path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" />
      </svg>
      Télétravail
    </button>
    <button class="filter-chip">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="7" width="20" height="10" rx="2" />
        <path d="M6 7V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2" />
      </svg>
      Secteur
    </button>
    <button class="filter-chip filter-chip--all">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="6" x2="20" y2="6" />
        <line x1="8" y1="12" x2="20" y2="12" />
        <line x1="12" y1="18" x2="20" y2="18" />
      </svg>
      Tous les filtres
    </button>
  </div>

  <!-- ── Grille d'offres ────────────────────────────────────── -->
  <section class="offers-section">
    <div class="offers-grid" id="offers-grid">
      <!-- Offres injectées dynamiquement via JS -->
    </div>
  </section>

  <script>
    // ─── Données des offres (base de données) ───
    const offres = [
      {
        id: 1,
        titre: "Data scientist risque TPE F/H",
        entreprise: "BPIFRANCE",
        entreprise_initiale: "BP",
        photo: null,
        localisation: "Maisons-Alfort",
        remote: "Télétravail fréquent",
        date_publication: "2026-03-18"
      },
      {
        id: 2,
        titre: "INGÉNIEUR(E) DATA – F/H",
        entreprise: "BPIFRANCE",
        entreprise_initiale: "BP",
        photo: null,
        localisation: "Maisons-Alfort",
        remote: "Télétravail fréquent",
        date_publication: "2026-03-16"
      },
      {
        id: 3,
        titre: "Data Analyst – Modern Data Stack (H/F)",
        entreprise: "HAPPYPAL",
        entreprise_initiale: "HP",
        photo: null,
        localisation: "Paris",
        remote: "Télétravail fréquent",
        date_publication: "2026-03-23"
      },
      {
        id: 4,
        titre: "Développeur Backend Python",
        entreprise: "TECHCORP",
        entreprise_initiale: "TC",
        photo: null,
        localisation: "Paris",
        remote: "Hybride",
        date_publication: "2026-03-20"
      },
      {
        id: 5,
        titre: "Chef de projet digital",
        entreprise: "DATASOLUTIONS",
        entreprise_initiale: "DS",
        photo: null,
        localisation: "Lyon",
        remote: "Présentiel",
        date_publication: "2026-03-15"
      },
      {
        id: 6,
        titre: "Développeur Frontend React",
        entreprise: "WEBAGENCY",
        entreprise_initiale: "WA",
        photo: null,
        localisation: "Bordeaux",
        remote: "Full remote",
        date_publication: "2026-03-10"
      }
    ];

    // ─── Formatage de la date ───────────────────────────────────
    function formatDate(dateStr) {
      const now = new Date();
      const date = new Date(dateStr);
      const diffMs = now - date;
      const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

      if (diffDays === 0) return "aujourd'hui";
      if (diffDays === 1) return "hier";
      if (diffDays === 2) return "avant-hier";
      if (diffDays < 30) return `il y a ${diffDays} jours`;
      return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' });
    }

    // ─── Génération des cartes ──────────────────────────────────
    function renderOffres(data) {
      const grid = document.getElementById('offers-grid');
      grid.innerHTML = '';

      data.forEach(offre => {
        const card = document.createElement('article');
        card.className = 'offer-card';

        const imageHtml = offre.photo
          ? `<img class="offer-card__image" src="${offre.photo}" alt="${offre.titre}" loading="lazy" />`
          : `<div class="offer-card__image-placeholder">Photo de l'entreprise</div>`;

        card.innerHTML = `
          ${imageHtml}
          <div class="offer-card__body">
            <h2 class="offer-card__title">${offre.titre}</h2>
            <div class="offer-card__company">
              <div class="offer-card__company-logo-placeholder">${offre.entreprise_initiale}</div>
              <span class="offer-card__company-name">${offre.entreprise}</span>
            </div>
            <div class="offer-card__tags">
              <span class="tag">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                ${offre.localisation}
              </span>
              <span class="tag">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                ${offre.remote}
              </span>
            </div>
          </div>
          <div class="offer-card__footer">
            <span class="offer-card__date">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              ${formatDate(offre.date_publication)}
            </span>
            <div class="offer-card__actions">
              <button title="Voir l'offre">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
              <button title="Sauvegarder">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
              </button>
            </div>
          </div>
        `;

        grid.appendChild(card);
      });
    }

    renderOffres(offres);
  </script>

</body>

</html>