<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — Connexion</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="template.css" />
  <style>
    :root {
      --color-primary:  #ECC023;
      --color-dark:     #2D2D2D;
      --color-medium:   #5A5A5A;
      --color-light-bg: #E8E8E8;
      --color-white:    #FFFFFF;
      --color-border:   #C8C8C8;
      --font-main:      'Space Grotesk', sans-serif;
      --radius-btn:     28px;
      --radius-card:    20px;
      --radius-input:   28px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-main);
      background-color: var(--color-light-bg);
      color: var(--color-dark);
      min-height: 100vh;
    }

    /* ── Logo top-left ── */
    .topbar {
      padding: 20px 32px;
    }

    .topbar__logo {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      text-decoration: none;
      gap: 2px;
    }

    .topbar__logo img {
      width: 48px;
      height: auto;
      mix-blend-mode: multiply;
    }

    .topbar__logo span {
      font-family: var(--font-main);
      font-weight: 700;
      font-size: 15px;
      color: var(--color-dark);
    }

    /* ── Tagline ── */
    .tagline {
      text-align: center;
      font-family: var(--font-main);
      font-weight: 700;
      font-size: 42px;
      color: var(--color-dark);
      margin: 8px 0 32px;
    }

    /* ── Card ── */
    .login-card {
      background: var(--color-white);
      border-radius: 32px;
      padding: 48px 56px;
      width: 100%;
      max-width: 520px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    /* ── Form group ── */
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .form-group label {
      font-family: var(--font-main);
      font-weight: 600;
      font-size: 16px;
      color: var(--color-dark);
    }

    .form-group input {
      height: 52px;
      border: 1.5px solid var(--color-border);
      border-radius: var(--radius-input);
      padding: 0 20px;
      font-family: var(--font-main);
      font-size: 16px;
      color: var(--color-dark);
      background: var(--color-white);
      outline: none;
      transition: border-color 0.2s;
    }

    .form-group input:focus {
      border-color: var(--color-primary);
    }

    /* ── Buttons ── */
    .btn-connect {
      width: 100%;
      height: 52px;
      background: var(--color-primary);
      border: none;
      border-radius: var(--radius-btn);
      font-family: var(--font-main);
      font-weight: 700;
      font-size: 18px;
      color: var(--color-dark);
      cursor: pointer;
      transition: opacity 0.2s;
      margin-top: 4px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
    }
    .btn-connect:hover { opacity: 0.88; }

    .divider {
      text-align: center;
      font-size: 15px;
      color: var(--color-medium);
    }

    .btn-google {
      width: 100%;
      height: 52px;
      background: var(--color-white);
      border: 1.5px solid var(--color-border);
      border-radius: var(--radius-btn);
      font-family: var(--font-main);
      font-weight: 500;
      font-size: 16px;
      color: var(--color-dark);
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: background 0.2s;
    }
    .btn-google:hover { background: #f5f5f5; }

    /* Google G icon */
    .google-icon {
      width: 20px;
      height: 20px;
      flex-shrink: 0;
    }

    /* ── Sign up link ── */
    .signup-link {
      text-align: center;
      font-size: 15px;
      color: var(--color-medium);
      margin-top: 8px;
    }

    .signup-link a {
      color: var(--color-primary);
      font-weight: 700;
      text-decoration: none;
    }
    .signup-link a:hover { text-decoration: underline; }
  </style>
</head>
<body>

  <!-- Logo cliquable → accueil -->
  <div class="topbar">
    <a href="acceuil.html" class="topbar__logo">
      <img src="/images/logo_landr.png" alt="Logo Landr" />
      <span>Landr</span>
    </a>
  </div>

  <!-- Tagline -->
  <h1 class="tagline">Inscrivez-vous. Décollez. Évoluez.</h1>

  <!-- Carte login -->
  <div class="login-card">

    <div class="form-group">
      <label for="identifiant">Identifiant</label>
      <input type="text" id="identifiant" placeholder="" />
    </div>

    <div class="form-group">
      <label for="password">Mot de passe</label>
      <input type="password" id="password" placeholder="" />
    </div>

    <button class="btn-connect">Se connecter</button>

    <p class="divider">ou</p>

    <button class="btn-google">
      <!-- Google G SVG -->
      <svg class="google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
      </svg>
      Continuer avec Google
    </button>

    <p class="signup-link">Pas encore inscrit(e) ? <a href="/inscription_candidat">S'inscrire</a></p>

  </div>

</body>
</html>