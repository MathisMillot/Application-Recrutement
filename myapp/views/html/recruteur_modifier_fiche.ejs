<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — Modifier la fiche de poste</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/admin.css" />
  <style>
    .fiche-form { max-width: 680px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
    .form-group label { font-weight: 600; font-size: 14px; color: var(--color-dark); }
    .form-group input,
    .form-group textarea,
    .form-group select {
      border: 1.5px solid var(--color-border, #C8C8C8);
      border-radius: 10px;
      padding: 10px 14px;
      font-family: inherit;
      font-size: 15px;
      color: var(--color-dark);
      background: #fff;
      outline: none;
      transition: border-color 0.2s;
      width: 100%;
    }
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus { border-color: var(--color-primary, #ECC023); }
    .form-group textarea { min-height: 120px; resize: vertical; }
    .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .required { color: #e53935; }
    .section-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #888; margin: 28px 0 16px; border-bottom: 1px solid #eee; padding-bottom: 8px; }
    .org-badge { display: inline-block; background: #f3f4f6; border-radius: 8px; padding: 8px 14px; font-size: 14px; color: #555; margin-bottom: 4px; }
  </style>
</head>

<body>
  <div class="admin-layout">

    <aside class="admin-sidebar">
      <div class="admin-sidebar__title">Landr Recruteur</div>
      <a href="/recruteur">Dashboard</a>
      <a href="/recruteur/fiches" class="active">Mes fiches de poste</a>
      <a href="/recruteur/fiches/nouvelle">+ Nouvelle fiche</a>
      <a href="/recruteur/offres/nouvelle">+ Nouvelle offre</a>
      <a href="/recruteur/organisation/nouvelle">+ Demander une organisation</a>
      <hr class="admin-sidebar__divider" />
      <a href="/offres">← Retour au site</a>
      <form method="POST" action="/logout" class="admin-sidebar__form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="admin-sidebar__logout">Se déconnecter</button>
      </form>
    </aside>

    <main class="admin-main">
      <div class="admin-header">
        <h1>Modifier la fiche de poste</h1>
        <a href="/recruteur/fiches" style="font-size:14px; color:#888; text-decoration:none;">← Retour aux fiches</a>
      </div>

      <div class="section-card fiche-form">
        <form method="POST" action="/recruteur/fiches/<%= fiche.id_fiche %>/modifier">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <p class="section-label">Identification du poste</p>

          <div class="form-group">
            <label>Intitulé du poste <span class="required">*</span></label>
            <input type="text" name="intitule" value="<%= fiche.intitule %>" required />
          </div>

          <div class="form-row-2">
            <div class="form-group">
              <label>Nom interne du poste <span class="required">*</span></label>
              <input type="text" name="nom_poste" value="<%= fiche.nom_poste %>" required />
            </div>
            <div class="form-group">
              <label>Responsable / Manager <span class="required">*</span></label>
              <input type="text" name="responsable" value="<%= fiche.responsable %>" required />
            </div>
          </div>

          <div class="form-group">
            <label>Organisation</label>
            <span class="org-badge"><%= fiche.organisation %> (SIREN : <%= fiche.siren_organisation %>)</span>
            <small style="color:#888; font-size:12px;">L'organisation ne peut pas être modifiée après création.</small>
          </div>

          <p class="section-label">Conditions du poste</p>

          <div class="form-row-2">
            <div class="form-group">
              <label>Lieu <span class="required">*</span></label>
              <input type="text" name="lieu" value="<%= fiche.lieu %>" required />
            </div>
            <div class="form-group">
              <label>Télétravail</label>
              <select name="remote">
                <option value=""       <%= !fiche.remote               ? 'selected' : '' %>>Non précisé</option>
                <option value="non"    <%= fiche.remote === 'non'      ? 'selected' : '' %>>Non</option>
                <option value="hybride"<%= fiche.remote === 'hybride'  ? 'selected' : '' %>>Hybride</option>
                <option value="full"   <%= fiche.remote === 'full'     ? 'selected' : '' %>>Full remote</option>
              </select>
            </div>
          </div>

          <div class="form-row-2">
            <div class="form-group">
              <label>Type de contrat</label>
              <select name="type_contrat">
                <option value=""           <%= !fiche.type_contrat                    ? 'selected' : '' %>>Non précisé</option>
                <option value="CDI"        <%= fiche.type_contrat === 'CDI'           ? 'selected' : '' %>>CDI</option>
                <option value="CDD"        <%= fiche.type_contrat === 'CDD'           ? 'selected' : '' %>>CDD</option>
                <option value="Stage"      <%= fiche.type_contrat === 'Stage'         ? 'selected' : '' %>>Stage</option>
                <option value="Alternance" <%= fiche.type_contrat === 'Alternance'    ? 'selected' : '' %>>Alternance</option>
                <option value="Freelance"  <%= fiche.type_contrat === 'Freelance'     ? 'selected' : '' %>>Freelance</option>
              </select>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; align-items:end;">
              <div class="form-group">
                <label>Salaire min (€/an) <span class="required">*</span></label>
                <input type="number" name="salaire_min" value="<%= fiche.salaire_min %>" min="0" step="1000" required />
              </div>
              <div class="form-group">
                <label>Salaire max (€/an) <span class="required">*</span></label>
                <input type="number" name="salaire_max" value="<%= fiche.salaire_max %>" min="0" step="1000" required />
              </div>
            </div>
          </div>

          <p class="section-label">Caractéristiques du poste</p>

          <div class="form-row-2">
            <div class="form-group">
              <label>Statut du poste</label>
              <select name="statut_poste">
                <option value=""          <%= !fiche.statut_poste                     ? 'selected' : '' %>>Non précisé</option>
                <option value="Cadre"     <%= fiche.statut_poste === 'Cadre'          ? 'selected' : '' %>>Cadre</option>
                <option value="ETAM"      <%= fiche.statut_poste === 'ETAM'           ? 'selected' : '' %>>ETAM</option>
                <option value="Technicien"<%= fiche.statut_poste === 'Technicien'     ? 'selected' : '' %>>Technicien</option>
                <option value="Employé"   <%= fiche.statut_poste === 'Employé'        ? 'selected' : '' %>>Employé</option>
                <option value="Ouvrier"   <%= fiche.statut_poste === 'Ouvrier'        ? 'selected' : '' %>>Ouvrier</option>
              </select>
            </div>
            <div class="form-group">
              <label>Type de métier</label>
              <input type="text" name="type_metier" value="<%= fiche.type_metier || '' %>" placeholder="ex: Informatique, Cybersécurité..." />
            </div>
          </div>

          <div class="form-group">
            <label>Rythme de travail</label>
            <input type="text" name="rythme" value="<%= fiche.rythme || '' %>" placeholder="ex: 35h/semaine, télétravail possible..." />
          </div>

          <div class="form-group">
            <label>Pièces demandées</label>
            <input type="text" name="pieces_demandees" value="<%= fiche.pieces_demandees || '' %>" placeholder="ex: CV, lettre de motivation, diplôme..." />
          </div>

          <p class="section-label">Description</p>

          <div class="form-group">
            <label>Description du poste</label>
            <textarea name="description"><%= fiche.description || '' %></textarea>
          </div>

          <div style="display:flex; gap:12px; margin-top:8px;">
            <button type="submit" class="btn btn--primary" style="height:44px; font-size:15px; padding:0 28px;">Enregistrer</button>
            <a href="/recruteur/fiches" class="btn" style="height:44px; font-size:15px; padding:0 20px; background:#eee; color:#333; text-decoration:none; display:inline-flex; align-items:center; border-radius:10px;">Annuler</a>
          </div>

        </form>
      </div>

    </main>
  </div>
</body>

</html>
