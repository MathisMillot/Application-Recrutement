<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — Profil professionnel</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../CSS/base.css" />
  <link rel="stylesheet" href="../CSS/components.css" />
  <link rel="stylesheet" href="../CSS/auth.css" />
  <style>
    :root {
      --color-primary:  #ECC023;
      --color-dark:     #2D2D2D;
      --color-medium:   #5A5A5A;
      --color-light-bg: #E8E8E8;
      --color-white:    #FFFFFF;
      --color-border:   #C8C8C8;
      --font-main:      'Space Grotesk', sans-serif;
      --radius-btn:     28px;
      --radius-input:   28px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-main);
      background-color: var(--color-light-bg);
      color: var(--color-dark);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 40px 24px 60px;
    }

    /* ── Logo ── */
    .topbar { margin-bottom: 28px; }

    .topbar a {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      text-decoration: none;
    }

    .topbar img {
      width: 80px;
      height: auto;
      mix-blend-mode: multiply;
    }

    .topbar span {
      font-family: var(--font-main);
      font-weight: 700;
      font-size: 22px;
      color: var(--color-dark);
    }

    /* ── Card ── */
    .card {
      background: var(--color-white);
      border-radius: 32px;
      padding: 48px 56px;
      width: 100%;
      max-width: 680px;
      display: flex;
      flex-direction: column;
      gap: 28px;
    }

    .card__title {
      font-family: var(--font-main);
      font-weight: 700;
      font-size: 28px;
      color: var(--color-dark);
      text-align: center;
    }

    /* ── Form ── */
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px 32px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .form-group label {
      font-family: var(--font-main);
      font-weight: 600;
      font-size: 15px;
      color: var(--color-dark);
    }

    .form-group select,
    .form-group input[type="number"] {
      height: 50px;
      border: 1.5px solid var(--color-border);
      border-radius: var(--radius-input);
      padding: 0 20px;
      font-family: var(--font-main);
      font-size: 15px;
      color: var(--color-dark);
      background: var(--color-white);
      outline: none;
      appearance: none;
      transition: border-color 0.2s;
      cursor: pointer;
    }

    .form-group select:focus,
    .form-group input[type="number"]:focus {
      border-color: var(--color-primary);
    }

    /* CV file input */
    .form-group--cv {
      grid-column: 1;
    }

    .file-input-wrapper {
      position: relative;
      height: 50px;
    }

    .file-input-wrapper input[type="file"] {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
      width: 100%;
      height: 100%;
    }

    .file-input-label {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 50px;
      border: 1.5px solid var(--color-border);
      border-radius: var(--radius-input);
      font-family: var(--font-main);
      font-size: 15px;
      color: var(--color-medium);
      background: var(--color-white);
      cursor: pointer;
      transition: border-color 0.2s;
    }

    .file-input-wrapper:hover .file-input-label {
      border-color: var(--color-primary);
    }

    /* ── Actions ── */
    .form-actions {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      margin-top: 4px;
    }

    .btn {
      height: 52px;
      width: 180px;
      border: none;
      border-radius: var(--radius-btn);
      font-family: var(--font-main);
      font-weight: 700;
      font-size: 17px;
      cursor: pointer;
      transition: opacity 0.2s;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }
    .btn:hover { opacity: 0.88; }

    .btn--yellow {
      background: var(--color-primary);
      color: var(--color-dark);
    }

    .btn--dark {
      background: #3B3B8E;
      color: #FFFFFF;
    }
  </style>
</head>
<body>

  <!-- Logo → accueil -->
  <div class="topbar">
    <a href="/accueil">
      <img src="/images/logo_landr.png" alt="Logo Landr" />
      <span>Landr</span>
    </a>
  </div>

  <!-- Card -->
  <div class="card">
    <h1 class="card__title">Profil professionnel</h1>

    <div class="form-row">

      <div class="form-group">
        <label>Niveau d'études </label>
        <select>
          <option value=""></option>
          <option>Bac</option>
          <option>Bac +2</option>
          <option>Bac +3</option>
          <option>Bac +5</option>
          <option>Doctorat</option>
        </select>
      </div>

      <div class="form-group">
        <label>Domaine / Spécialité </label>
        <select>
          <option value=""></option>
          <option>Informatique</option>
          <option>Marketing</option>
          <option>Finance</option>
          <option>Ressources Humaines</option>
          <option>Design</option>
        </select>
      </div>

      <div class="form-group">
        <label>Années d'expérience</label>
        <input type="number" min="0" max="50" />
      </div>

      <div class="form-group">
        <label>Type de contrat souhaité </label>
        <select>
          <option value=""></option>
          <option>CDI</option>
          <option>CDD</option>
          <option>Stage</option>
          <option>Alternance</option>
          <option>Freelance</option>
        </select>
      </div>

      <div class="form-group form-group--cv">
        <label>CV</label>
        <div class="file-input-wrapper">
          <input type="file" accept=".pdf,.doc,.docx" id="cv" />
          <div class="file-input-label">Choose file</div>
        </div>
      </div>

    </div>

    <div class="form-actions">
      <a href="/informations_personnelles" class="btn btn--yellow">Retour</a>
      <a href="#" class="btn btn--dark">Créer mon Compte</a>
    </div>
  </div>

</body>
</html>