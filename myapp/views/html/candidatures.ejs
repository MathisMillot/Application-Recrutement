<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — Candidatures</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../CSS/base.css" />
  <link rel="stylesheet" href="../CSS/components.css" />
  <link rel="stylesheet" href="../CSS/table.css" />

</head>
<body>

  <nav class="navbar">
    <a href="/accueil" class="navbar__brand">
      <img src="/images/logo_landr.png" alt="Logo Landr" />
      <span>Landr</span>
    </a>
  </nav>

  <div class="page-wrapper">
    <h1 class="page-title mt-32">Liste des candidatures</h1>

    <div class="card w-full">
      <% if (candidatures.length === 0) { %>
        <p class="text-center">Aucune candidature trouvée.</p>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Candidat</th>
              <th>Email</th>
              <th>Offre</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% candidatures.forEach(function(c) { %>
              <tr>
                <td><%= c.id_candidature %></td>
                <td><%= c.prenom %> <%= c.nom %></td>
                <td><%= c.email %></td>
                <td><%= c.offre_description || '—' %></td>
                <td><%= new Date(c.date).toLocaleDateString('fr-FR') %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

</body>
</html>
