<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — Modifier l'offre</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/admin.css" />
  <style>
    .offre-form { max-width: 580px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
    .form-group label { font-weight: 600; font-size: 14px; color: var(--color-dark); }
    .form-group input,
    .form-group select {
      border: 1.5px solid var(--color-border, #C8C8C8);
      border-radius: 10px;
      padding: 10px 14px;
      font-family: inherit;
      font-size: 15px;
      color: var(--color-dark);
      background: #fff;
      outline: none;
      width: 100%;
    }
    .form-group input:focus,
    .form-group select:focus { border-color: var(--color-primary, #ECC023); }
    .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .required { color: #e53935; }
    .fiche-card {
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 16px 20px;
      margin-bottom: 24px;
    }
    .fiche-card__title { font-weight: 700; font-size: 16px; margin-bottom: 4px; }
    .fiche-card__org { font-size: 13px; color: #888; margin-bottom: 10px; }
    .fiche-card .tags { display: flex; gap: 8px; flex-wrap: wrap; }
    .fiche-card .tag { background: #e5e7eb; border-radius: 20px; padding: 3px 10px; font-size: 12px; color: #555; }
    .fiche-card__edit { font-size: 13px; color: var(--color-primary, #ECC023); text-decoration: none; display: inline-block; margin-top: 10px; }
  </style>
</head>

<body>
  <div class="admin-layout">

    <aside class="admin-sidebar">
      <div class="admin-sidebar__title">Landr Recruteur</div>
      <a href="/recruteur">Dashboard</a>
      <a href="/recruteur/fiches">Mes fiches de poste</a>
      <a href="/recruteur/fiches/nouvelle">+ Nouvelle fiche</a>
      <a href="/recruteur/offres/nouvelle">+ Nouvelle offre</a>
      <hr class="admin-sidebar__divider" />
      <a href="/offres">← Retour au site</a>
      <form method="POST" action="/logout" class="admin-sidebar__form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="admin-sidebar__logout">Se déconnecter</button>
      </form>
    </aside>

    <main class="admin-main">
      <div class="admin-header">
        <h1>Modifier l'offre #<%= offre.id_offre %></h1>
        <a href="/recruteur" style="font-size:14px; color:#888; text-decoration:none;">← Retour au dashboard</a>
      </div>

      <div class="section-card offre-form">

        <!-- Fiche de poste liée (lecture seule) -->
        <% if (offre.intitule) { %>
        <div class="fiche-card">
          <div style="font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:#aaa; margin-bottom:8px;">Fiche de poste</div>
          <div class="fiche-card__title"><%= offre.intitule %></div>
          <div class="fiche-card__org"><%= offre.organisation %></div>
          <div class="tags">
            <% if (offre.lieu) { %><span class="tag">📍 <%= offre.lieu %></span><% } %>
            <% if (offre.type_contrat) { %><span class="tag">📄 <%= offre.type_contrat %></span><% } %>
            <% if (offre.remote === 'full') { %><span class="tag">🏠 Full remote</span>
            <% } else if (offre.remote === 'hybride') { %><span class="tag">🏠 Hybride</span><% } %>
            <% if (offre.salaire_min > 0) { %>
              <span class="tag">💶
                <%= offre.salaire_min.toLocaleString('fr-FR') %>€<% if (offre.salaire_max && offre.salaire_max !== offre.salaire_min) { %> – <%= offre.salaire_max.toLocaleString('fr-FR') %>€<% } %>
              </span>
            <% } %>
          </div>
          <% if (offre.id_fiche) { %>
            <a href="/recruteur/fiches/<%= offre.id_fiche %>/modifier" class="fiche-card__edit">Modifier la fiche de poste →</a>
          <% } %>
        </div>
        <% } else { %>
        <div style="background:#fff7ed; border:1px solid #fed7aa; border-radius:10px; padding:12px 16px; margin-bottom:20px; font-size:14px; color:#92400e;">
          Cette offre n'est pas liée à une fiche de poste (ancienne offre).
        </div>
        <% } %>

        <!-- Seuls statut et date sont modifiables -->
        <form method="POST" action="/recruteur/offres/<%= offre.id_offre %>/modifier">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="form-row-2">
            <div class="form-group">
              <label>Statut</label>
              <select name="statut">
                <option value="publiee"  <%= offre.statut === 'publiee'  ? 'selected' : '' %>>Publiée</option>
                <option value="inactive" <%= offre.statut === 'inactive' ? 'selected' : '' %>>Inactive (brouillon)</option>
              </select>
            </div>
            <div class="form-group">
              <label>Date d'expiration <span class="required">*</span></label>
              <input type="date" name="date_expiration"
                value="<%= offre.date_expiration ? new Date(offre.date_expiration).toISOString().split('T')[0] : '' %>"
                required />
            </div>
          </div>

          <div style="display:flex; gap:12px; margin-top:8px;">
            <button type="submit" class="btn btn--primary" style="height:44px; font-size:15px; padding:0 28px;">Enregistrer</button>
            <a href="/recruteur" class="btn" style="height:44px; font-size:15px; padding:0 20px; background:#eee; color:#333; text-decoration:none; display:inline-flex; align-items:center; border-radius:10px;">Annuler</a>
          </div>

        </form>
      </div>

    </main>
  </div>
</body>

</html>
