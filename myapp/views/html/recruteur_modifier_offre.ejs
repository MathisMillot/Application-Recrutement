<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — Modifier l'offre</title>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/base.css" />
  <link rel="stylesheet" href="/css/components.css" />
  <link rel="stylesheet" href="/css/admin.css" />
  <style>
    .offre-form { max-width: 640px; }
    .form-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
    .form-group label { font-weight: 600; font-size: 14px; color: var(--color-dark); }
    .form-group input,
    .form-group textarea,
    .form-group select {
      border: 1.5px solid var(--color-border, #C8C8C8);
      border-radius: 10px;
      padding: 10px 14px;
      font-family: inherit;
      font-size: 15px;
      color: var(--color-dark);
      background: #fff;
      outline: none;
      width: 100%;
    }
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus { border-color: var(--color-primary, #ECC023); }
    .form-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .required { color: #e53935; }
  </style>
</head>

<body>
  <div class="admin-layout">

    <aside class="admin-sidebar">
      <div class="admin-sidebar__title">Landr Recruteur</div>
      <a href="/recruteur">Dashboard</a>
      <a href="/recruteur/offres/nouvelle">+ Nouvelle offre</a>
      <hr class="admin-sidebar__divider" />
      <a href="/offres">← Retour au site</a>
      <form method="POST" action="/logout" class="admin-sidebar__form">
        <button type="submit" class="admin-sidebar__logout">Se déconnecter</button>
      </form>
    </aside>

    <main class="admin-main">
      <div class="admin-header">
        <h1>Modifier l'offre #<%= offre.id_offre %></h1>
        <a href="/recruteur" style="font-size:14px; color:#888; text-decoration:none;">← Retour au dashboard</a>
      </div>

      <div class="section-card offre-form">
        <form method="POST" action="/recruteur/offres/<%= offre.id_offre %>/modifier">

          <div class="form-group">
            <label>Intitulé du poste <span class="required">*</span></label>
            <input type="text" name="description" value="<%= offre.description %>" required />
          </div>

          <div class="form-row-2">
            <div class="form-group">
              <label>Statut</label>
              <select name="statut">
                <option value="publiee"  <%= offre.statut === 'publiee'  ? 'selected' : '' %>>Publiée</option>
                <option value="inactive" <%= offre.statut === 'inactive' ? 'selected' : '' %>>Inactive (brouillon)</option>
              </select>
            </div>
            <div class="form-group">
              <label>Date d'expiration <span class="required">*</span></label>
              <input type="date" name="date_expiration"
                value="<%= offre.date_expiration ? new Date(offre.date_expiration).toISOString().split('T')[0] : '' %>"
                required />
            </div>
          </div>

          <div class="form-row-2">
            <div class="form-group">
              <label>Localisation</label>
              <input type="text" name="localisation" value="<%= offre.localisation || '' %>" placeholder="ex: Paris, Lyon..." />
            </div>
            <div class="form-group">
              <label>Télétravail</label>
              <select name="remote">
                <option value=""       <%= !offre.remote              ? 'selected' : '' %>>Non précisé</option>
                <option value="non"    <%= offre.remote === 'non'     ? 'selected' : '' %>>Non</option>
                <option value="hybride"<%= offre.remote === 'hybride' ? 'selected' : '' %>>Hybride</option>
                <option value="full"   <%= offre.remote === 'full'    ? 'selected' : '' %>>Full remote</option>
              </select>
            </div>
          </div>

          <div class="form-row-2">
            <div class="form-group">
              <label>Type de contrat</label>
              <select name="type_contrat">
                <option value=""           <%= !offre.type_contrat                  ? 'selected' : '' %>>Non précisé</option>
                <option value="CDI"        <%= offre.type_contrat === 'CDI'         ? 'selected' : '' %>>CDI</option>
                <option value="CDD"        <%= offre.type_contrat === 'CDD'         ? 'selected' : '' %>>CDD</option>
                <option value="Stage"      <%= offre.type_contrat === 'Stage'       ? 'selected' : '' %>>Stage</option>
                <option value="Alternance" <%= offre.type_contrat === 'Alternance'  ? 'selected' : '' %>>Alternance</option>
                <option value="Freelance"  <%= offre.type_contrat === 'Freelance'   ? 'selected' : '' %>>Freelance</option>
              </select>
            </div>
            <div class="form-group">
              <label>Salaire minimum (€/an)</label>
              <input type="number" name="salaire_min" value="<%= offre.salaire_min || '' %>" placeholder="ex: 35000" min="0" step="1000" />
            </div>
          </div>

          <div style="display:flex; gap:12px; margin-top:8px;">
            <button type="submit" class="btn btn--primary" style="height:44px; font-size:15px; padding:0 28px;">Enregistrer</button>
            <a href="/recruteur" class="btn" style="height:44px; font-size:15px; padding:0 20px; background:#eee; color:#333; text-decoration:none; display:inline-flex; align-items:center; border-radius:10px;">Annuler</a>
          </div>

        </form>
      </div>

    </main>
  </div>
</body>

</html>
