<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Landr — Entreprises</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../CSS/base.css" />
  <link rel="stylesheet" href="../CSS/components.css" />
  <link rel="stylesheet" href="../CSS/offres.css" />
  <style>
    .org-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
    @media (max-width: 1100px) { .org-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 750px)  { .org-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px)  { .org-grid { grid-template-columns: 1fr; } }

    .org-card {
      background: #fff;
      border-radius: 16px;
      padding: 28px 20px 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      cursor: pointer;
      transition: box-shadow 0.2s, transform 0.2s;
      text-decoration: none;
      color: inherit;
    }
    .org-card:hover {
      box-shadow: 0 8px 28px rgba(0,0,0,0.1);
      transform: translateY(-3px);
    }
    .org-card__logo {
      width: 72px;
      height: 72px;
      border-radius: 16px;
      object-fit: cover;
      background: var(--color-light-bg, #f4f4f4);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 22px;
      color: #555;
      flex-shrink: 0;
      overflow: hidden;
    }
    .org-card__logo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .org-card__name {
      font-weight: 700;
      font-size: 15px;
      text-align: center;
      line-height: 1.3;
    }
    .org-card__meta {
      font-size: 12px;
      color: #888;
      text-align: center;
    }
    .org-card__badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      background: #d1fae5;
      color: #065f46;
    }
    .org-card__badge--attente {
      background: #fff9c4;
      color: #f57f17;
    }
    .org-card__offers {
      font-size: 13px;
      font-weight: 600;
      color: var(--color-primary, #ECC023);
    }
    .page-hero {
      background: #fff;
      border-bottom: 1px solid #E5E5E5;
      padding: 40px 48px 32px;
    }
    .page-hero h1 {
      font-size: 32px;
      font-weight: 700;
      margin-bottom: 16px;
    }
    .search-bar {
      display: flex;
      align-items: center;
      gap: 12px;
      background: #F5F5F5;
      border: 1.5px solid #D0D0D0;
      border-radius: 30px;
      padding: 0 20px;
      height: 50px;
      max-width: 480px;
    }
    .search-bar input {
      border: none;
      background: transparent;
      font-family: inherit;
      font-size: 15px;
      width: 100%;
      outline: none;
    }
    .search-bar button {
      background: var(--color-primary, #ECC023);
      border: none;
      border-radius: 20px;
      padding: 6px 18px;
      font-family: inherit;
      font-weight: 700;
      font-size: 14px;
      cursor: pointer;
      white-space: nowrap;
    }
  </style>
</head>

<body>

  <!-- Navbar -->
  <nav class="navbar">
    <a class="navbar__brand" href="/offres">
      <img src="/images/logo_landr.png" alt="Landr logo" />
      <span>Landr</span>
    </a>
    <div class="navbar__nav">
      <a href="/offres">Trouver un job</a>
      &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
      <a href="/organisations" style="color: var(--color-primary, #ECC023);">Trouver une entreprise</a>
    </div>

    <% if (user) { %>
    <div class="navbar__user" id="user-menu" style="margin-left:auto;">
      <div class="navbar__avatar">
        <% if (user.photo_profil) { %>
          <img src="/uploads/<%= user.photo_profil %>" alt="avatar" />
        <% } else { %>
          <%= user.prenom[0] %><%= user.nom[0] %>
        <% } %>
      </div>
      <span>Mon espace</span>
      <div class="user-dropdown" id="user-dropdown">
        <a href="/profil_candidat">Mon profil</a>
        <a href="/modifier_profil">Modifier mon profil</a>
        <div class="dropdown-divider"></div>
        <form method="POST" action="/logout" style="margin:0;padding:0">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="dropdown-logout">Se déconnecter</button>
        </form>
      </div>
    </div>
    <% } else { %>
    <a href="/connection" class="btn btn--primary" style="white-space:nowrap;margin-left:auto;">Se connecter</a>
    <% } %>
  </nav>

  <!-- Hero + recherche -->
  <div class="page-hero">
    <h1>Découvrez les entreprises</h1>
    <form class="search-bar" method="GET" action="/organisations">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input type="text" name="q" placeholder="Rechercher une entreprise..." value="<%= q %>" />
      <button type="submit">Rechercher</button>
    </form>
  </div>

  <!-- Contenu -->
  <section style="max-width:1300px;margin:0 auto;padding:40px 48px;">

    <p style="font-size:14px;color:#888;margin-bottom:28px;">
      <strong style="color:#2D2D2D;"><%= organisations.length %></strong>
      entreprise<%= organisations.length > 1 ? 's' : '' %> trouvée<%= organisations.length > 1 ? 's' : '' %>
      <% if (q) { %> pour <em>«&nbsp;<%= q %>&nbsp;»</em><% } %>
    </p>

    <% if (organisations.length === 0) { %>
      <div style="text-align:center;padding:60px 0;color:#888;">
        <p style="font-size:18px;font-weight:600;color:#555;">Aucune entreprise trouvée.</p>
        <a href="/organisations" style="display:inline-block;margin-top:12px;font-size:14px;color:var(--color-primary);">Voir toutes les entreprises</a>
      </div>
    <% } else { %>
      <div class="org-grid">
        <% organisations.forEach(function(org) { %>
          <a href="/organisations/<%= org.siren %>" class="org-card">
            <div class="org-card__logo">
              <% if (org.photo_profil) { %>
                <img src="/uploads/<%= org.photo_profil %>" alt="<%= org.nom %>" />
              <% } else { %>
                <%= org.nom.substring(0,2).toUpperCase() %>
              <% } %>
            </div>
            <span class="org-card__name"><%= org.nom %></span>
            <% if (org.type) { %>
              <span class="org-card__meta"><%= org.type %><% if (org.siege_social) { %> · <%= org.siege_social %><% } %></span>
            <% } %>
            <% if (Number(org.nb_offres) > 0) { %>
              <span class="org-card__offers"><%= org.nb_offres %> offre<%= org.nb_offres > 1 ? 's' : '' %></span>
            <% } else { %>
              <span class="org-card__meta">Aucune offre active</span>
            <% } %>
          </a>
        <% }); %>
      </div>
    <% } %>
  </section>

  <script>
    const menu = document.getElementById('user-menu');
    const dropdown = document.getElementById('user-dropdown');
    if (menu && dropdown) {
      menu.addEventListener('click', e => { e.stopPropagation(); dropdown.classList.toggle('open'); });
      document.addEventListener('click', () => dropdown.classList.remove('open'));
    }
  </script>

</body>
</html>
